# Murphy Configuration
# Copy this file to .env and fill in your values

# === Required ===
OPENAI_API_KEY=your_openai_api_key_here

# === Murphy REST API (optional, for murphy-api server) ===
# MURPHY_API_KEY=your_murphy_api_key_here
# MURPHY_API_HOST=0.0.0.0
# MURPHY_API_PORT=8000
# MURPHY_MAX_CONCURRENT_JOBS=2
# MURPHY_REQUEST_TIMEOUT=1800
# MURPHY_JOB_TIMEOUT_OVERRIDE=

# === Browser Configuration (optional) ===
# Path to Chrome/Chromium executable
# BROWSER_USE_EXECUTABLE_PATH=/path/to/chrome

# Run browser in headless mode (default: true)
# BROWSER_USE_HEADLESS=true

# === Logging (optional) ===
BROWSER_USE_LOGGING_LEVEL=info

# === Telemetry ===
# Telemetry is disabled. No data is collected or sent.
