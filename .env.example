# Murphy Configuration
# Copy this file to .env and fill in your values

# === Required ===
# Default model is gpt-4o — set your OpenAI key here (or use --model for another provider)
OPENAI_API_KEY=your_openai_api_key_here

# === Alternative LLM Providers (set one if using --model) ===
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# GOOGLE_API_KEY=your_google_api_key_here
# GROQ_API_KEY=your_groq_api_key_here
# DEEPSEEK_API_KEY=your_deepseek_api_key_here

# === Murphy API (optional, for REST API mode) ===
# MURPHY_API_KEY=your_murphy_api_key_here

# === Browser Configuration (optional) ===
# Path to Chrome/Chromium executable
# BROWSER_USE_EXECUTABLE_PATH=/path/to/chrome

# Run browser in headless mode (default: true)
# BROWSER_USE_HEADLESS=true

# === Logging (optional) ===
BROWSER_USE_LOGGING_LEVEL=info

# === Telemetry ===
# The vendored browser-use library sends anonymous usage telemetry by default.
# Set to false to disable.
ANONYMIZED_TELEMETRY=true
